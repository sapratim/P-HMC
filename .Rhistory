pdf("nn_acf_HMC_PervsDur.pdf", height = 6, width = 6)
lag.max <- 100
acf_per_hmc <- acf(pxhmc_per[[1]][,rand[1]], plot = FALSE, lag.max = lag.max)$acf
acf_dur_hmc <- acf(pxhmc_dur[[2]][,rand[1]], plot = FALSE, lag.max = lag.max)$acf
