# Compute dimension assuming square image
dimen <- sqrt(length(image_vec))
if (dimen != as.integer(dimen)) {
stop("Error: Image vector length must be a perfect square")
}
dimen <- as.integer(dimen)
# Reshape into matrix
image_mat <- matrix(image_vec, dimen, dimen)
# Perform 3-level Haar wavelet decomposition
trans <- dwt.2d(image_mat, wf = "haar", 3)
# Compute L1 norm
wave_sum <- sum(abs(unlist(trans)))
# Print result
print(wave_sum)
wavelet_l1(true_pixel_vec)
trans
c(unlist(trans))
sum((unlist(trans)))
c(unlist(trans))[250]
c(unlist(trans))[256]
c(unlist(trans))[251]
