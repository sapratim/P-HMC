log_pi <- function(y, x)   ##### input x as vector
{
x <- as.matrix(x, nrow = sqrt(nrow(x)), ncol = sqrt(nrow(x)))
Hx <- convol_func(H, x)
Psi.x <- beta_pen*convol_func(Psi, x)
f <- (norm(y - Hx, 2)^2)/(2*sigma2)
g <- beta_pen*norm(Psi.x, 1)
return(-(f+g))
}
